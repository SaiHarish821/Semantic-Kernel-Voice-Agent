# ─────────────────────────────────────────────────────────────
#  Sainsbury's AI Voice Agent — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Azure OpenAI / VoiceLive ──────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── Azure OpenAI Chat (used by SK for plugin orchestration) ───
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5

# ── Application Settings ──────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────
DATABASE_PATH=./data/sainsburys.db

# ── Voice Settings ────────────────────────────────────────────
VOICE_NAME=alloy
AUDIO_FORMAT=pcm16
AUDIO_SAMPLE_RATE=24000

# ── Store Configuration ───────────────────────────────────────
DEFAULT_STORE_ID=ST001

# ── Session Settings ──────────────────────────────────────────
MAX_CONTEXT_TURNS=6
SESSION_TIMEOUT_SECONDS=300

# ── CORS (comma-separated allowed origins) ────────────────────
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
